# Template only — no real secrets here. Copy to `.env` (gitignored) and fill in.
#   cp .env.example .env
# See root README.md "Using the provider" section.
#
# Local testing: `make testacc`, `make testunit`, `make docs`, etc. automatically
# load `.env` from the repo root when the file exists (see GNUmakefile).
# You can still load manually:   set -a && source .env && set +a

# Required for OAuth client credentials (Admin → OAuth integrations)
GENESYSCLOUD_OAUTHCLIENT_ID=
GENESYSCLOUD_OAUTHCLIENT_SECRET=

# AWS region where your Genesys Cloud org is hosted (e.g. us-east-1)
GENESYSCLOUD_REGION=

# Optional: use a static access token instead of client credentials
# GENESYSCLOUD_ACCESS_TOKEN=

# Optional: HTTP proxy (see README "Proxy Configuration")
# GENESYSCLOUD_PROXY_HOST=
# GENESYSCLOUD_PROXY_PORT=
# GENESYSCLOUD_PROXY_PROTOCOL=
# GENESYSCLOUD_PROXY_AUTH_USERNAME=
# GENESYSCLOUD_PROXY_AUTH_PASSWORD=

# Optional: consistency checker (see README)
# BYPASS_CONSISTENCY_CHECKER=
# CONSISTENCY_CHECKS=
